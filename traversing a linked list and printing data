#include <stdio.h>
#include <stdlib.h>

struct node{
    int data;
    struct node *link;
};

void Print_data(struct node *head);   

int main() {
    struct node *head = NULL;  
    Print_data(head);
    return 0;
}

void Print_data(struct node *head){
    if(head == NULL){
        printf("Linked List is empty");
        return;
    }
    
    struct node *ptr = head;
    
    while(ptr != NULL){
        printf("%d ", ptr->data);
        ptr = ptr->link;
    }
}
