#include <stdio.h>
#include <stdlib.h>

struct node{
    int data;
    struct node *link;
};

void add_at_end(struct node *head, int data){
    struct node *ptr, *temp;
    
    temp = (struct node*)malloc(sizeof(struct node));
    temp->data = data;
    temp->link = NULL;
    
    ptr = head;
    
    while(ptr->link != NULL){
        ptr = ptr->link;
    }
    
    ptr->link = temp;
}

int main(){
    struct node *head = (struct node*)malloc(sizeof(struct node));
    
    head->data = 45;
    head->link = NULL;
    
    add_at_end(head, 67);
    
    return 0;
}
